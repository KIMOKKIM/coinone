# 코인원 API (필수)
COINONE_ACCESS_KEY=your_access_key
COINONE_SECRET_KEY=your_secret_key

# 실거래 여부 (기본: false = 드라이런)
LIVE_TRADING=false

# 거래 심볼 (콤마 구분)
SYMBOLS=BTC/KRW,ETH/KRW

# 모드: scalper | grid
MODE=scalper

# Oracle DB 로그 (선택)
ORACLE_DSN=localhost:1521/XE
ORACLE_USER=bot_user
ORACLE_PASSWORD=your_password
ORACLE_TABLE=BOT_TRADES
